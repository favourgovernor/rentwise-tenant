# ── Supabase ──────────────────────────────────────────
# Same project as your Flutter app — copy from Supabase
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Service role key — NEVER expose this to the browser.
# Used only in API routes (M-Pesa callback, etc.)
# Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── M-Pesa Daraja (sandbox to start) ─────────────────
# Get these from developer.safaricom.co.ke → My Apps
MPESA_CONSUMER_KEY=YOUR_SANDBOX_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_SANDBOX_CONSUMER_SECRET
MPESA_SHORTCODE=174379
MPESA_PASSKEY=YOUR_SANDBOX_PASSKEY
MPESA_ENV=sandbox
# Once deployed to Vercel, this becomes your real domain:
MPESA_CALLBACK_URL=https://rentwise-tenant.vercel.app/api/mpesa/callback

# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://rentwise-tenant.vercel.app
